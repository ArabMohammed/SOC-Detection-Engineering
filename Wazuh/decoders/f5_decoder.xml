<decoder name="f5-asm">
  <type>syslog</type>
  <prematch type="pcre2">CEF:0\|F5\|ASM\|[^\|]+\|(.+)|CEF:0\|F5\|[^\|]+\|[^\|]+\|.+</prematch>
</decoder>

